{
  "name": "blockchain-loan-system",
  "version": "1.0.0",
  "description": "Blockchain-Based Loan Management System",
  "private": true,
  "scripts": {
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "node": "npx hardhat node --hostname 127.0.0.1",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network localhost",
    "blocks": "npx hardhat run scripts/block-demo.js --network localhost",
    "blocks:local": "npx hardhat run scripts/block-demo.js",
    "user": "npx hardhat run scripts/user-cli.js --network localhost",
    "verifier": "npx hardhat run scripts/verifier-cli.js --network localhost",
    "monitor": "npx hardhat run scripts/monitor-blocks.js --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "dotenv": "^17.4.2"
  }
}
